# Auth (required)
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# Database (PostgreSQL — required for Vercel; use Neon free tier)
# https://neon.tech — copy the pooled connection string
DATABASE_URL="postgresql://user:password@host.neon.tech/neondb?sslmode=require"

# Email — pick ONE option (restart dev server after changing)

# Option A: Resend with your verified domain (production)
EMAIL_PROVIDER=resend
AUTH_RESEND_KEY=re_xxx
EMAIL_FROM="YAP <noreply@yap.college>"

# Option B: SMTP fallback for local dev (set EMAIL_PROVIDER=smtp)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-gmail-app-password
# SMTP_FROM="YAP <you@gmail.com>"

# Stripe (optional — nightlife ticket checkout)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
